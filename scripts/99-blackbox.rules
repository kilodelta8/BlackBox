# create or copy this file at /etc/udev/rules.d/99-blackbox.rules


# RTL-SDR V4
SUBSYSTEM=="usb", ATTRS{idVendor}=="0bda", ATTRS{idProduct}=="2838", SYMLINK+="sdr_panadapter"

# Alfa Wi-Fi (AWUS036ACM)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0e8d", ATTRS{idProduct}=="7612", SYMLINK+="hacking_wifi"

# USB GPS
SUBSYSTEM=="usb", ATTRS{idVendor}=="1546", ATTRS{idProduct}=="01a7", SYMLINK+="blackbox_gps"
